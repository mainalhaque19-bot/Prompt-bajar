rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "mainalhaque19@gmail.com";
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Prompts
    match /prompts/{promptId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isSignedIn() 
        && request.resource.data.title is string
        && request.resource.data.prompt is string
        && request.resource.data.imageUrl is string
        && request.resource.data.category is string
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn()
        && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'viewsCount', 'copiesCount']));
    }

    // Shayari
    match /shayari/{shayariId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.content is string
        && request.resource.data.category is string
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn()
        && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount']));
    }

    // User Likes
    match /users/{userId}/likes/{likeId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.itemId is string
        && request.resource.data.type in ['prompt', 'shayari']
        && request.resource.data.addedAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
